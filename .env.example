# ── Payload CMS Environment Variables ──────────────────────
# Add these to your Vercel project settings (Settings > Environment Variables)

# Supabase PostgreSQL connection string
DATABASE_URI=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Payload CMS secret (generate a random 32+ char string)
PAYLOAD_SECRET=your-secret-key-here

# Public URL of this CMS deployment (update after first Vercel deploy)
NEXT_PUBLIC_SERVER_URL=https://your-cms.vercel.app
